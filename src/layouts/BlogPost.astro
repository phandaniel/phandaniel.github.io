---
import MainLayout from './MainLayout.astro';

interface Props {
    title: string;
    description: string;
    pubDate: Date;
}

const { title, description, pubDate } = Astro.props;

const formattedDate = (date: Date) => date.toLocaleDateString('en-us', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<MainLayout title={title} description={description}>
    <article class="max-w-4xl mx-auto px-6 pt-32 pb-20">
        <header class="max-w-2xl mx-auto mb-16 text-center">
            <time class="text-xs font-bold text-blue-600 uppercase tracking-widest mb-4 block">
                {formattedDate(pubDate)}
            </time>
            <h1 class="font-serif text-4xl md:text-6xl text-zinc-900 leading-tight mb-6">
                {title}
            </h1>
            <p class="text-xl text-zinc-500 font-medium leading-relaxed italic">
                {description}
            </p>
        </header>

        <div class="prose prose-zinc prose-lg max-w-2xl mx-auto prose-headings:font-serif prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline prose-blockquote:border-l-blue-600 prose-blockquote:bg-blue-50/50 prose-blockquote:py-1 prose-blockquote:px-6 prose-code:text-blue-600 prose-code:bg-zinc-100 prose-code:px-1 prose-code:rounded">
            <slot />
        </div>

        <footer class="max-w-2xl mx-auto mt-24 pt-12 border-t border-zinc-200">
            <a href="/blog" class="text-sm font-bold text-zinc-400 hover:text-zinc-900 transition-colors uppercase tracking-widest no-underline">
                ← Back to journal
            </a>
        </footer>
    </article>
</MainLayout>
