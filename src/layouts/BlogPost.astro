---
import MainLayout from './MainLayout.astro';
const { title, description, pubDate } = Astro.props;
const fmt = (d: Date) => d.toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' });
---
<MainLayout title={title} description={description}>
    <article class="max-w-4xl mx-auto px-6 pt-32 pb-20">
        <header class="max-w-2xl mx-auto mb-16 text-center">
            <time class="text-xs font-bold text-brand-blue uppercase tracking-widest mb-4 block">{fmt(pubDate)}</time>
            <h1 class="font-serif text-4xl md:text-6xl mb-6">{title}</h1>
            <p class="text-xl text-text-muted italic leading-relaxed">{description}</p>
        </header>
        <div class="prose prose-zinc prose-lg mx-auto prose-headings:font-serif prose-a:text-brand-blue prose-a:no-underline hover:prose-a:underline prose-code:text-brand-blue prose-code:bg-zinc-100 prose-code:px-1 prose-code:rounded">
            <slot />
        </div>
        <footer class="max-w-2xl mx-auto mt-24 pt-12 border-t border-zinc-200">
            <a href="/blog" class="text-xs font-bold text-zinc-400 hover:text-text-main uppercase tracking-widest">← Back to journal</a>
        </footer>
    </article>
</MainLayout>
