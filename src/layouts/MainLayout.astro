---
import Header from '../components/Header.astro';
import { SITE_METADATA } from '../data/constants';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
    canonicalURL?: string | URL;
    image?: string;
}

const { 
    title, 
    description = SITE_METADATA.defaultDescription,
    canonicalURL = new URL(Astro.url.pathname, Astro.site || SITE_METADATA.siteUrl),
    image = "/og-image.png" // Fallback to a default OG image
} = Astro.props;

const siteTitle = `${title} | ${SITE_METADATA.author}`;
---
<html lang="en" class="selection:bg-zinc-200">
	<head>
		<meta charset="UTF-8" /><meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <title>{siteTitle}</title>

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={siteTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(image, canonicalURL)} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={siteTitle} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={new URL(image, canonicalURL)} />
		
		<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,600;1,6..72,400&display=swap" rel="stylesheet">
	</head>
	<body class="font-sans">
		<Header />
		<main><slot /></main>
		<footer class="max-w-4xl mx-auto px-6 py-20 border-t border-zinc-200/50 text-sm text-text-muted flex flex-col md:flex-row justify-between items-center gap-6">
			<p>&copy; {new Date().getFullYear()} Daniel Phan.</p>
			<div class="flex gap-8">
				<a href="https://github.com/phandaniel" class="hover:text-text-main" target="_blank" rel="noopener noreferrer">GitHub</a>
				<a href="https://www.linkedin.com/in/daniel-phan-mba-59776413a/" class="hover:text-text-main" target="_blank" rel="noopener noreferrer">LinkedIn</a>
			</div>
		</footer>
	</body>
</html>
