---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Home">
	<section class="max-w-4xl mx-auto px-6 flex flex-col justify-center min-h-[80vh] py-32">
		<h1 class="font-serif text-5xl md:text-7xl leading-tight mb-8">Hi, I'm Daniel. <br/>Software engineer & digital craftsman.</h1>
		<p class="text-xl md:text-2xl text-text-muted max-w-2xl leading-relaxed mb-16">Dedicated to building minimalist, high-performance web applications with precision and professional design.</p>
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-8 border-t border-zinc-200/60 pt-8 max-w-lg">
			<div><span class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Location</span><span class="text-sm">Washington, D.C. Metro</span></div>
			<div><span class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Status</span><span class="text-sm flex items-center gap-2"><span class="relative flex h-2 w-2"><span class="animate-ping absolute h-full w-full rounded-full bg-zinc-400 opacity-75"></span><span class="relative rounded-full h-2 w-2 bg-zinc-500"></span></span>Building the forge</span></div>
		</div>
	</section>
</MainLayout>
