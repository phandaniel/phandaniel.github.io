---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formattedDate = (date: Date) => date.toLocaleDateString('en-us', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
});
---

<MainLayout title="Home">
	<!-- Hero Section -->
	<section class="max-w-5xl mx-auto px-8 pt-32 pb-32 md:pt-48 md:pb-48 text-center md:text-left">
		<div class="max-w-3xl mx-auto md:mx-0">
			<span class="inline-block text-accent-blue font-bold text-xs uppercase tracking-[0.2em] mb-6">
				Digital Craftsman
			</span>
			<h1 class="text-6xl md:text-8xl font-semibold tracking-heading leading-[0.9] text-text-primary mb-10">
				Precision in every <span class="text-accent-blue">pixel.</span>
			</h1>
			<p class="text-xl md:text-2xl text-text-primary/80 font-normal leading-relaxed max-w-2xl">
				I am Daniel Phan, a full-stack developer dedicated to building minimalist, high-performance web applications that matter.
			</p>
		</div>
	</section>

	<!-- Blog Feed Section -->
	<section class="max-w-5xl mx-auto px-8 pb-32">
		<div class="flex items-center gap-4 mb-16">
			<h2 class="text-xs font-semibold uppercase tracking-[0.3em] text-text-secondary whitespace-nowrap">
				Tech Writing
			</h2>
			<div class="h-[1px] w-full bg-border-light/50"></div>
		</div>
		
		<div class="grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-10">
			{posts.map((post) => (
				<article class="card p-10 flex flex-col">
					<a href={`/blog/${post.slug}`} class="flex flex-col h-full no-underline">
						<time class="text-xs font-bold text-accent-blue uppercase tracking-widest mb-6">
							{formattedDate(post.data.pubDate)}
						</time>
						<div class="flex-grow">
							<h3 class="text-2xl font-semibold tracking-heading text-text-primary group-hover:text-accent-blue transition-colors mb-4">
								{post.data.title}
							</h3>
							<p class="text-lg text-text-primary/70 leading-relaxed line-clamp-3">
								{post.data.description}
							</p>
						</div>
						<div class="mt-10 flex items-center text-xs font-bold uppercase tracking-widest text-accent-blue">
							Read Article
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
						</div>
					</a>
				</article>
			))}
		</div>
	</section>
</MainLayout>
