---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formattedDate = (date: Date) => date.toLocaleDateString('en-us', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
});
---

<MainLayout title="Home">
	<!-- Hero Section -->
	<section class="max-w-5xl mx-auto section-padding text-center md:text-left pt-32 pb-48">
		<div class="max-w-3xl">
			<span class="inline-block text-accent-blue font-bold text-xs uppercase tracking-[0.2em] mb-6">
				Digital Craftsman
			</span>
			<h1 class="text-6xl md:text-8xl font-semibold tracking-heading leading-[0.9] text-text-primary mb-10">
				Precision in every <span class="text-accent-blue">pixel.</span>
			</h1>
			<p class="text-xl md:text-2xl text-text-secondary font-normal leading-relaxed max-w-2xl">
				I am Daniel Phan, a full-stack developer dedicated to building minimalist, high-performance web applications that matter.
			</p>
		</div>
	</section>

	<!-- Blog Feed Section -->
	<section class="max-w-5xl mx-auto section-padding pt-0 pb-32">
		<div class="flex items-center gap-6 mb-16">
			<h2 class="text-xs font-semibold uppercase tracking-[0.3em] text-text-secondary whitespace-nowrap">
				Tech Writing
			</h2>
			<div class="h-[1px] w-full bg-border-light/40"></div>
		</div>
		
		<div class="grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-10">
			{posts.map((post) => (
				<article class="card p-10 flex flex-col h-full group">
					<time class="text-[10px] font-bold text-accent-blue uppercase tracking-widest mb-6">
						{formattedDate(post.data.pubDate)}
					</time>
					<h3 class="text-2xl font-semibold tracking-heading text-text-primary mb-6 group-hover:text-accent-blue transition-colors">
						<a href={`/blog/${post.slug}`} class="text-inherit no-underline">
							{post.data.title}
						</a>
					</h3>
					<p class="text-text-secondary leading-relaxed mb-8 flex-grow">
						{post.data.description}
					</p>
					<div>
						<a href={`/blog/${post.slug}`} class="text-accent-blue font-bold text-xs uppercase tracking-widest hover:underline">
							Read Article
						</a>
					</div>
				</article>
			))}
		</div>
	</section>
</MainLayout>
