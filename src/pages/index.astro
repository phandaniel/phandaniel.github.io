---
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);

// Manual Featured Projects (or fetch from API and filter)
const featuredRepos = [
    {
        name: "Website Redesign",
        description: "A high-performance portfolio redesign focusing on accessibility and modern aesthetics.",
        html_url: "https://github.com/dphan18/dphan18.github.io",
        language: "Astro"
    },
    {
        name: "Data Visualizer",
        description: "A browser-based tool for exploring and visualizing complex CSV datasets.",
        html_url: "https://github.com/dphan18/data-visualizer",
        language: "TypeScript"
    }
];

const formattedDate = (date: Date) => date.toLocaleDateString('en-us', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
});
---

<MainLayout title="Home">
	<!-- Hero Section -->
	<section class="max-w-4xl mx-auto px-6 flex flex-col justify-center min-h-[50vh] py-32">
		<h1 class="font-serif text-4xl md:text-6xl text-zinc-900 leading-[1.1] mb-8">
			Hi, I'm Daniel. <br/>
			A software engineer & digital craftsman.
		</h1>
		<p class="font-sans text-xl md:text-2xl text-zinc-500 max-w-2xl leading-relaxed mb-12">
			Dedicated to building minimalist, high-performance web applications with a focus on precision and professional design.
		</p>
		<div class="flex gap-4">
			<a href="/projects" class="px-6 py-3 bg-zinc-900 text-white rounded-lg hover:bg-zinc-800 transition-colors font-medium text-sm">
				View Projects
			</a>
		</div>
	</section>

	<!-- Selected Writing Section -->
	<section class="max-w-4xl mx-auto px-6 py-24">
		<h2 class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-400 mb-8">
			Selected Writing
		</h2>
		
		<div class="flex flex-col gap-2">
			{posts.map((post) => (
				<a href={`/blog/${post.id}`} class="group flex flex-col sm:flex-row sm:justify-between py-5 border-b border-zinc-100 hover:bg-white/60 transition-all px-4 -mx-4 rounded-xl">
					<span class="font-serif text-2xl text-zinc-900 group-hover:text-blue-600 transition-colors">
						{post.data.title}
					</span>
					<span class="font-sans text-sm text-zinc-500 tabular-nums mt-2 sm:mt-0 self-start sm:self-center bg-stone-100 px-3 py-1 rounded-full group-hover:bg-blue-50 transition-colors">
						{formattedDate(post.data.pubDate)}
					</span>
				</a>
			))}
		</div>
	</section>

	<!-- Featured Projects (Bento Grid) -->
	<section class="max-w-4xl mx-auto px-6 py-24">
		<h2 class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-400 mb-8">
			Featured Projects
		</h2>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
			{featuredRepos.map((repo) => (
				<ProjectCard 
					title={repo.name}
					description={repo.description}
					url={repo.html_url}
					language={repo.language}
				/>
			))}
		</div>
	</section>
</MainLayout>
