---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Home">
	<!-- Hero Section -->
	<section class="max-w-4xl mx-auto px-6 flex flex-col justify-center min-h-[80vh] py-32">
		<h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-zinc-900 tracking-tight leading-tight mb-6">
			Hi, I'm Daniel. <br/>
			A software engineer & digital craftsman.
		</h1>
		<p class="font-sans text-xl md:text-2xl text-zinc-500 max-w-2xl leading-relaxed">
			Dedicated to building minimalist, high-performance web applications with a focus on precision and professional design.
		</p>

		<!-- Metadata Block -->
		<div class="mt-16 grid grid-cols-1 sm:grid-cols-2 gap-8 border-t border-zinc-200/60 pt-8 max-w-lg">
			<div>
				<span class="block text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400 mb-2">Location</span>
				<span class="text-sm text-zinc-600 font-sans">Washington, D.C. Metro</span>
			</div>
			<div>
				<span class="block text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400 mb-2">Status</span>
				<span class="text-sm text-zinc-600 font-sans flex items-center gap-2">
					<span class="relative flex h-2 w-2">
					   <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-zinc-400 opacity-75"></span>
					   <span class="relative inline-flex rounded-full h-2 w-2 bg-zinc-500"></span>
					</span>
					Building the digital forge
				</span>
			</div>
		</div>
	</section>
</MainLayout>
