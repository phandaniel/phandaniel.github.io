---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formattedDate = (date: Date) => date.toLocaleDateString('en-us', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
});
---

<MainLayout title="Home">
	<!-- Hero Section -->
	<section class="max-w-5xl mx-auto px-8 pt-32 pb-32 md:pt-48 md:pb-48">
		<div class="max-w-3xl">
			<span class="inline-block text-blue-600 font-bold text-xs uppercase tracking-[0.2em] mb-6">
				Digital Craftsman
			</span>
			<h1 class="text-6xl md:text-8xl font-black tracking-tightest leading-[0.9] text-black mb-10">
				Precision in every <span class="text-blue-600">pixel.</span>
			</h1>
			<p class="text-xl md:text-2xl text-gray-500 font-medium leading-relaxed max-w-2xl">
				I am Daniel Phan, a full-stack developer dedicated to building minimalist, high-performance web applications that matter.
			</p>
		</div>
	</section>

	<!-- Blog Feed Section -->
	<section class="max-w-5xl mx-auto px-8 pb-32">
		<div class="flex items-center gap-4 mb-16">
			<h2 class="text-xs font-black uppercase tracking-[0.3em] text-gray-400 whitespace-nowrap">
				Tech Writing
			</h2>
			<div class="h-[1px] w-full bg-black/[0.03]"></div>
		</div>
		
		<div class="grid gap-20">
			{posts.map((post) => (
				<article class="group relative">
					<a href={`/blog/${post.slug}`} class="block">
						<div class="grid md:grid-cols-[1fr_3fr] gap-4 md:gap-12 items-start">
							<time class="text-sm font-bold text-gray-400 mt-1">
								{formattedDate(post.data.pubDate)}
							</time>
							<div>
								<h3 class="text-2xl md:text-3xl font-bold tracking-tight text-black group-hover:text-blue-600 transition-colors mb-4">
									{post.data.title}
								</h3>
								<p class="text-lg text-gray-500 leading-relaxed mb-6 line-clamp-2 font-medium">
									{post.data.description}
								</p>
								<div class="flex items-center text-xs font-black uppercase tracking-widest text-blue-600 opacity-0 group-hover:opacity-100 transition-all translate-x-[-10px] group-hover:translate-x-0">
									Read Article
									<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
								</div>
							</div>
						</div>
					</a>
				</article>
			))}
		</div>
	</section>
</MainLayout>

<style>
	.tracking-tightest {
		letter-spacing: -0.05em;
	}
</style>
