---
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { fetchFeaturedRepos } from '../utils/github';
import { ArrowRight } from 'lucide-astro';
import { getCollection } from 'astro:content';
import { PHILOSOPHIES, TECH_STACK, SITE_METADATA } from '../data/constants';

const curatedProjects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const githubFeatured = curatedProjects.length < 2 ? (await fetchFeaturedRepos()).slice(0, 2 - curatedProjects.length) : [];

const formattedProjects = [
    ...curatedProjects.map(p => ({
        title: p.data.title,
        description: p.data.description,
        url: p.data.url,
        language: p.data.language,
        imageUrl: p.data.image
    })),
    ...githubFeatured
].slice(0, 2);
---
<MainLayout title="Home" description={SITE_METADATA.defaultDescription}>
	<!-- Hero Section -->
	<section class="max-w-4xl mx-auto px-6 pt-40 pb-16 md:pb-24">
		<h1 class="font-serif text-5xl md:text-7xl leading-tight mb-8">
			Hi, I'm Daniel. <br/>
			Software engineer & digital craftsman.
		</h1>
		<p class="text-xl md:text-2xl text-zinc-400 font-normal max-w-2xl leading-relaxed mb-16 italic">
			Dedicated to building minimalist, high-performance web applications with precision and professional design.
		</p>
		
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-12 border-t border-zinc-200/60 pt-12 max-w-xl">
			<div>
				<span class="section-label !mb-3">Location</span>
				<span class="text-sm font-medium hover:text-brand-blue transition-colors cursor-default underline decoration-zinc-200 decoration-1 underline-offset-4 hover:decoration-brand-blue">
                    {SITE_METADATA.location}
                </span>
			</div>
			<div>
				<span class="section-label !mb-3">Status</span>
				<span class="text-sm flex items-center gap-2 font-medium">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute h-full w-full rounded-full bg-zinc-400 opacity-75"></span>
						<span class="relative rounded-full h-2 w-2 bg-zinc-500"></span>
					</span>
					{SITE_METADATA.status}
				</span>
			</div>
		</div>
	</section>

	<!-- Selected Works Section -->
	<section class="max-w-4xl mx-auto px-6 py-16 md:py-24">
		<span class="section-label">Selected Works</span>
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			{formattedProjects.map(p => (
				<ProjectCard 
					title={p.title} 
					description={p.description} 
					url={p.url} 
					language={p.language} 
					imageUrl={p.imageUrl} 
				/>
			))}
		</div>
		<div class="mt-8">
			<a href="/projects" aria-label="View all projects" class="group inline-flex items-center gap-2 text-sm font-bold text-zinc-900 hover:text-brand-blue transition-colors no-underline">
				View all projects 
				<ArrowRight size={16} class="transition-transform group-hover:translate-x-1" aria-hidden="true" />
			</a>
		</div>
	</section>

	<!-- Philosophy Section -->
	<section class="max-w-4xl mx-auto px-6 py-16 md:py-24">
		<span class="section-label">Philosophy</span>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
			{PHILOSOPHIES.map(p => (
				<div class="flex flex-col gap-4">
					<span class="font-mono text-xs text-zinc-300" aria-hidden="true">{p.id}</span>
					<h3 class="text-xl font-semibold tracking-tight">{p.title}</h3>
					<p class="text-zinc-500 text-sm leading-relaxed">{p.desc}</p>
				</div>
			))}
		</div>
	</section>

	<!-- Tech Stack Section -->
	<section class="max-w-4xl mx-auto px-6 py-16 md:py-24">
		<span class="section-label">Toolkit</span>
		<div class="flex flex-wrap gap-3">
			{TECH_STACK.map(s => (
				<span class="px-4 py-2 bg-white border border-zinc-200/60 rounded-full text-xs font-semibold text-zinc-600 cursor-default hover:border-zinc-300 transition-colors">
					{s}
				</span>
			))}
		</div>
	</section>
</MainLayout>
