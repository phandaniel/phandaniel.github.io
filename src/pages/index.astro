---
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { fetchFeaturedRepos } from '../utils/github';
import { ArrowRight } from 'lucide-astro';

const featured = (await fetchFeaturedRepos()).slice(0, 2);

const philosophies = [
	{ id: "01", title: "Architecture", desc: "Building robust foundations with modular, scalable, and maintainable systems." },
	{ id: "02", title: "Performance", desc: "Optimizing for speed and efficiency to ensure sub-second response times." },
	{ id: "03", title: "Precision", desc: "A meticulous approach to UI detail, ensuring every pixel serves a purpose." }
];

const stack = ["Astro", "TypeScript", "Tailwind CSS", "Node.js", "React", "Next.js", "PostgreSQL", "Docker"];
---
<MainLayout title="Home">
	<!-- Hero Section -->
	<section class="max-w-4xl mx-auto px-6 flex flex-col justify-center min-h-[85vh] py-32">
		<h1 class="font-serif text-6xl md:text-8xl leading-tight mb-8">
			Hi, I'm Daniel. <br/>
			Software engineer & digital craftsman.
		</h1>
		<p class="text-xl md:text-2xl text-zinc-400 font-normal max-w-2xl leading-relaxed mb-16 italic">
			Dedicated to building minimalist, high-performance web applications with precision and professional design.
		</p>
		
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-12 border-t border-zinc-200/60 pt-12 max-w-xl">
			<div>
				<span class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-3 block">Location</span>
				<span class="text-sm font-medium hover:text-brand-blue transition-colors cursor-default">Washington, D.C. Metro</span>
			</div>
			<div>
				<span class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-3 block">Status</span>
				<span class="text-sm flex items-center gap-2 font-medium">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute h-full w-full rounded-full bg-zinc-400 opacity-75"></span>
						<span class="relative rounded-full h-2 w-2 bg-zinc-500"></span>
					</span>
					Building the forge
				</span>
			</div>
		</div>
	</section>

	<!-- Selected Works Section -->
	<section class="max-w-4xl mx-auto px-6 py-48">
		<span class="section-label">Selected Works</span>
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
			{featured.map(p => (
				<ProjectCard 
					title={p.title} 
					description={p.description} 
					url={p.url} 
					language={p.language} 
					imageUrl={p.imageUrl} 
				/>
			))}
		</div>
		<a href="/projects" class="group inline-flex items-center gap-2 text-sm font-bold text-zinc-900 hover:text-brand-blue transition-colors">
			View all projects 
			<ArrowRight size={16} class="transition-transform group-hover:translate-x-1" />
		</a>
	</section>

	<!-- Philosophy Section -->
	<section class="max-w-4xl mx-auto px-6 py-48">
		<span class="section-label">Philosophy</span>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
			{philosophies.map(p => (
				<div class="flex flex-col gap-4">
					<span class="font-mono text-xs text-zinc-300">{p.id}</span>
					<h3 class="text-xl font-semibold">{p.title}</h3>
					<p class="text-zinc-500 text-sm leading-relaxed">{p.desc}</p>
				</div>
			))}
		</div>
	</section>

	<!-- Tech Stack Section -->
	<section class="max-w-4xl mx-auto px-6 py-48">
		<span class="section-label">Toolkit</span>
		<div class="flex flex-wrap gap-3">
			{stack.map(s => (
				<span class="px-4 py-2 bg-white border border-zinc-200/60 rounded-full text-xs font-semibold text-zinc-600 cursor-default hover:border-zinc-300 transition-colors">
					{s}
				</span>
			))}
		</div>
	</section>
</MainLayout>
