---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// 1. Data Fetching & Sorting
const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 2. Data Grouping by Year
const postsByYear = allPosts.reduce((acc, post) => {
    const year = post.data.pubDate.getFullYear();
    if (!acc[year]) acc[year] = [];
    acc[year].push(post);
    return acc;
}, {} as Record<number, typeof allPosts>);

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));

const formatDate = (date: Date) => date.toLocaleDateString('en-us', {
	month: 'short',
	day: '2-digit',
});
---

<MainLayout title="Writing">
    <div class="max-w-2xl mx-auto px-6 py-20">
        <!-- Main Header -->
        <header class="mb-20">
            <h1 class="font-serif text-5xl text-zinc-900 tracking-tight">Writing</h1>
        </header>

        <div class="space-y-20">
            {years.map(year => (
                <section>
                    <!-- Sticky Year Sub-header -->
                    <div class="sticky top-16 z-20 bg-stone-50/90 backdrop-blur-sm py-4 border-b border-zinc-200/50 mb-4">
                        <h2 class="font-sans text-sm font-bold tracking-[0.2em] text-zinc-400">
                            {year}
                        </h2>
                    </div>
                    
                    <!-- Article Rows (No prose classes used) -->
                    <div class="flex flex-col">
                        {postsByYear[Number(year)].map((post) => (
                            <a 
                                href={`/blog/${post.id}`} 
                                class="group flex items-baseline justify-between py-6 border-b border-zinc-100 hover:border-zinc-200 transition-colors no-underline"
                            >
                                <span class="font-serif text-xl md:text-2xl text-zinc-800 group-hover:text-blue-600 transition-colors duration-300">
                                    {post.data.title}
                                </span>
                                <span class="font-sans text-sm text-zinc-400 tabular-nums whitespace-nowrap ml-8">
                                    {formatDate(post.data.pubDate)}
                                </span>
                            </a>
                        ))}
                    </div>
                </section>
            ))}
        </div>
    </div>
</MainLayout>
