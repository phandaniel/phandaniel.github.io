---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await post.render();

const formattedDate = (date: Date) => date.toLocaleDateString('en-us', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<MainLayout title={post.data.title} description={post.data.description}>
	<article class="prose prose-lg max-w-none prose-headings:text-apple-text prose-p:text-apple-secondary prose-a:text-apple-blue">
		<header class="mb-12 border-b border-apple-border pb-12">
			<time class="block text-sm font-bold text-apple-blue uppercase tracking-widest mb-4">
				{formattedDate(post.data.pubDate)}
			</time>
			<h1 class="text-4xl md:text-5xl font-extrabold mb-6">
				{post.data.title}
			</h1>
			<p class="text-xl text-apple-secondary leading-relaxed italic">
				{post.data.description}
			</p>
		</header>
		<div class="markdown-content">
			<Content />
		</div>
	</article>

	<div class="mt-20 pt-10 border-t border-apple-border">
		<a href="/" class="text-sm font-bold text-apple-secondary hover:text-apple-blue transition-colors flex items-center">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5m7 7-7-7 7-7"/></svg>
			Back to Home
		</a>
	</div>
</MainLayout>

<style is:global>
	.markdown-content h1, .markdown-content h2, .markdown-content h3 {
		@apply mt-10 mb-6;
	}
	.markdown-content p {
		@apply mb-6 leading-relaxed;
	}
	.markdown-content ul {
		@apply list-disc list-inside mb-6 space-y-2 text-apple-secondary;
	}
	.markdown-content strong {
		@apply text-apple-text font-bold;
	}
</style>
