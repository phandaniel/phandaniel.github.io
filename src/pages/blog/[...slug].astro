---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await post.render();

const formattedDate = (date: Date) => date.toLocaleDateString('en-us', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<MainLayout title={post.data.title} description={post.data.description}>
	<article class="max-w-3xl mx-auto">
		<header class="mb-16 border-b border-border-light/50 pb-12">
			<time class="block text-xs font-bold text-accent-blue uppercase tracking-[0.2em] mb-4">
				{formattedDate(post.data.pubDate)}
			</time>
			<h1 class="text-4xl md:text-5xl font-semibold tracking-heading text-text-primary mb-6">
				{post.data.title}
			</h1>
			<p class="text-xl text-text-primary/70 leading-relaxed italic font-normal">
				{post.data.description}
			</p>
		</header>
		<div class="markdown-content text-lg leading-body text-text-primary/90">
			<Content />
		</div>
	</article>

	<div class="max-w-3xl mx-auto mt-20 pt-10 border-t border-border-light/50">
		<a href="/" class="text-sm font-bold text-text-secondary hover:text-accent-blue transition-colors flex items-center no-underline">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5m7 7-7-7 7-7"/></svg>
			Back to Home
		</a>
	</div>
</MainLayout>

<style is:global>
	.markdown-content h1, .markdown-content h2, .markdown-content h3 {
		@apply mt-12 mb-6 font-semibold tracking-heading text-text-primary;
	}
	.markdown-content h2 { @apply text-3xl; }
	.markdown-content h3 { @apply text-2xl; }
	
	.markdown-content p {
		@apply mb-8 leading-body;
	}
	.markdown-content ul {
		@apply list-disc list-outside ml-6 mb-8 space-y-3 text-text-primary/80;
	}
	.markdown-content strong {
		@apply text-text-primary font-semibold;
	}
	.markdown-content blockquote {
		@apply border-l-4 border-accent-blue pl-6 py-1 my-8 italic text-text-primary/70;
	}
</style>
