---
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Fetch GitHub repos
const response = await fetch('https://api.github.com/users/dphan18/repos?sort=updated&per_page=12');
const repos = await response.json();

const featuredRepos = Array.isArray(repos) ? repos.filter(repo => !repo.fork) : [];
---

<MainLayout title="Projects">
	<div class="max-w-4xl mx-auto px-6 py-12">
		<header class="mb-16">
			<h1 class="font-serif text-5xl md:text-6xl text-zinc-900 leading-tight mb-4">Projects</h1>
			<p class="font-sans text-lg text-zinc-500 max-w-xl">
				A dashboard of technical solutions, architectural experiments, and open-source contributions.
			</p>
		</header>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			{featuredRepos.map((repo) => (
				<ProjectCard 
					title={repo.name.replace(/-/g, ' ')}
					description={repo.description || "No description provided."}
					url={repo.html_url}
					language={repo.language}
				/>
			))}
		</div>

		{featuredRepos.length === 0 && (
			<div class="p-20 text-center bg-white border border-zinc-200 rounded-3xl text-zinc-400 font-medium">
				Syncing with the digital forge...
			</div>
		)}
	</div>
</MainLayout>
