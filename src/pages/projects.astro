---
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { fetchFeaturedRepos } from '../utils/github';
import { getCollection } from 'astro:content';
import { SITE_METADATA } from '../data/constants';
import { Terminal } from 'lucide-astro';

const curatedProjects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const githubRepos = await fetchFeaturedRepos();

// Filter out GitHub repos that are already in curated projects
const curatedUrls = new Set(curatedProjects.map(p => p.data.url));
const filteredGithub = githubRepos.filter(r => !curatedUrls.has(r.url));

const allProjects = [
    ...curatedProjects.map(p => ({
        title: p.data.title,
        description: p.data.description,
        url: p.data.url,
        language: p.data.language,
        imageUrl: p.data.image
    })),
    ...filteredGithub
];
---

<MainLayout 
    title="Projects" 
    description="Explore a curated dashboard of technical solutions, ranging from high-performance web applications to advanced system implementations."
>
	<div class="max-w-6xl mx-auto px-6 py-20">
		<!-- Dashboard Header -->
		<header class="mb-20">
            <div class="flex items-center gap-3 text-brand-blue mb-4">
                <Terminal size={24} strokeWidth={2.5} />
                <span class="text-xs font-bold uppercase tracking-[0.3em]">Engineering Portfolio</span>
            </div>
			<h1 class="font-serif text-5xl md:text-7xl text-zinc-900 leading-tight mb-6">
                Projects
            </h1>
			<p class="font-sans text-xl text-zinc-500 max-w-2xl leading-relaxed">
				A dashboard of technical solutions, architectural experiments, and open-source contributions. Focused on performance, precision, and clean code.
			</p>
		</header>

		<!-- Projects Dashboard Grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			{allProjects.map((project) => (
				<ProjectCard 
					title={project.title} 
					description={project.description} 
					url={project.url} 
					language={project.language} 
					imageUrl={project.imageUrl} 
				/>
			))}
		</div>

		{allProjects.length === 0 && (
			<div class="p-20 text-center bg-white border border-zinc-200 rounded-3xl">
				<a 
                    href={`https://github.com/phandaniel`} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="font-serif text-2xl text-zinc-900 hover:text-brand-blue transition-colors inline-flex items-center gap-2 no-underline"
                >
					View my digital forge on GitHub 
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-1" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
				</a>
			</div>
		)}
	</div>
</MainLayout>
