---
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Fetch GitHub repos
const response = await fetch('https://api.github.com/users/dphan18/repos?sort=updated&per_page=6');
const repos = await response.json();

const featuredRepos = Array.isArray(repos) ? repos.filter(repo => !repo.fork) : [];
---

<MainLayout title="Projects">
	<header class="mb-16">
		<h1 class="text-4xl font-extrabold mb-4">Featured Work</h1>
		<p class="text-lg text-apple-secondary max-w-xl">
			A curated selection of applications and experiments, synced directly from GitHub.
		</p>
	</header>

	<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
		{featuredRepos.map((repo) => (
			<ProjectCard 
				title={repo.name.replace(/-/g, ' ')}
				description={repo.description || "No description provided."}
				url={repo.html_url}
				language={repo.language}
				stars={repo.stargazers_count}
			/>
		))}
	</div>

	{featuredRepos.length === 0 && (
		<div class="p-10 text-center border-2 border-dashed border-apple-border rounded-2xl text-apple-secondary">
			Unable to load repositories. Please check connection or API limits.
		</div>
	)}
</MainLayout>
