---
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Fetch GitHub repos
const response = await fetch('https://api.github.com/users/dphan18/repos?sort=updated&per_page=6');
const repos = await response.json();

const featuredRepos = Array.isArray(repos) ? repos.filter(repo => !repo.fork) : [];
---

<MainLayout title="Projects">
	<header class="max-w-5xl mx-auto px-8 pt-32 pb-20">
		<h1 class="text-5xl md:text-7xl font-semibold tracking-heading leading-tight text-text-primary mb-8">
			Crafted <span class="text-accent-blue">Solutions.</span>
		</h1>
		<p class="text-xl md:text-2xl text-text-primary/70 font-normal leading-relaxed max-w-xl">
			A curated selection of applications and experiments, synced directly from my GitHub.
		</p>
	</header>

	<section class="max-w-5xl mx-auto px-8 pb-32">
		<div class="grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-12">
			{featuredRepos.map((repo) => (
				<ProjectCard 
					title={repo.name.replace(/-/g, ' ')}
					description={repo.description || "No description provided."}
					url={repo.html_url}
					language={repo.language}
					stars={repo.stargazers_count}
				/>
			))}
		</div>

		{featuredRepos.length === 0 && (
			<div class="p-20 text-center border border-border-light bg-bg-surface rounded-card text-text-secondary font-semibold tracking-tight">
				Syncing with GitHub...
			</div>
		)}
	</section>
</MainLayout>
