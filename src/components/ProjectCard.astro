---
interface Props {
	title: string;
	description: string;
	url: string;
	language?: string;
}

const { title, description, url, language } = Astro.props;
---

<a href={url} target="_blank" rel="noopener noreferrer" class="group block h-full p-8 bg-white rounded-2xl border border-zinc-200 hover:border-zinc-300 hover:shadow-sm transition-all flex flex-col justify-between">
	<div>
		<div class="flex justify-between items-start mb-6">
			<h3 class="text-xl font-medium text-zinc-900 tracking-tight">
				{title}
			</h3>
			<div class="text-zinc-400 transition-transform group-hover:-translate-y-1 group-hover:translate-x-1">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
			</div>
		</div>
		<p class="text-zinc-500 text-sm leading-relaxed line-clamp-3">
			{description}
		</p>
	</div>
	
	<div class="mt-8 flex flex-wrap gap-2">
		{language && (
			<span class="px-2.5 py-1 bg-stone-100 text-zinc-600 text-[10px] font-bold uppercase tracking-wider rounded-md">
				{language}
			</span>
		)}
	</div>
</a>
