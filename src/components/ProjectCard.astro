---
interface Props {
	title: string;
	description: string;
	url: string;
	language?: string;
	stars?: number;
}

const { title, description, url, language, stars } = Astro.props;
---

<div class="card p-10 flex flex-col h-full group">
	<div class="flex justify-between items-start mb-8">
		<div class="w-10 h-10 bg-accent-blue/5 text-accent-blue rounded-lg flex items-center justify-center">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-4.5-2-7-2"/></svg>
		</div>
		{language && (
			<span class="text-[10px] font-bold uppercase tracking-widest text-text-secondary bg-bg-body px-3 py-1.5 rounded-full">
				{language}
			</span>
		)}
	</div>
	
	<h3 class="text-xl font-semibold tracking-heading text-text-primary mb-4 capitalize group-hover:text-accent-blue transition-colors">
		{title}
	</h3>
	<p class="text-text-secondary font-normal leading-relaxed mb-8 flex-grow">
		{description}
	</p>
	
	<div>
		<a href={url} target="_blank" rel="noopener noreferrer" class="btn-primary text-xs uppercase tracking-widest">
			View Repository
		</a>
	</div>
</div>
