---
const { title, description, url, language, imageUrl } = Astro.props;
---
<a href={url} target="_blank" rel="noopener" class="group card flex flex-col overflow-hidden">
	{imageUrl && <div class="h-40 overflow-hidden border-b border-zinc-100"><img src={imageUrl} alt={title} class="w-full h-full object-cover grayscale-[0.4] opacity-90 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500" /></div>}
	<div class="p-6 flex flex-col justify-between flex-grow">
		<div>
			<div class="flex justify-between items-start mb-4">
				<h3 class="text-lg group-hover:text-brand-blue transition-colors leading-tight">{title}</h3>
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-400 group-hover:-translate-y-1 group-hover:translate-x-1 transition-transform"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
			</div>
			<p class="text-text-muted text-sm line-clamp-3 mb-6">{description}</p>
		</div>
		{language && <span class="px-2 py-1 bg-stone-100 text-text-muted text-[10px] font-bold uppercase rounded self-start">{language}</span>}
	</div>
</a>
