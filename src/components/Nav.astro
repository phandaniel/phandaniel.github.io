---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname === "/" ? "" : pathname.slice(1).replace(/\/$/, "");
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/70 backdrop-blur-2xl border-b border-black/[0.03]">
    <nav class="max-w-5xl mx-auto px-8 h-20 flex items-center justify-between">
        <a href="/" class="text-xl font-black tracking-tighter text-black hover:opacity-50 transition-opacity">
            HD
        </a>
        <div class="flex gap-12">
            <a 
                href="/" 
                class={`text-sm font-bold tracking-tight transition-all hover:text-black ${currentPath === "" ? "text-black" : "text-gray-400"}`}
            >
                Home
            </a>
            <a 
                href="/projects" 
                class={`text-sm font-bold tracking-tight transition-all hover:text-black ${currentPath === "projects" ? "text-black" : "text-gray-400"}`}
            >
                Projects
            </a>
        </div>
    </nav>
</header>
