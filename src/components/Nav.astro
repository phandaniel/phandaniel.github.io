---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname === "/" ? "" : pathname.slice(1).replace(/\/$/, "");
---

<header class="fixed top-0 left-0 right-0 z-50 bg-bg-body/80 backdrop-blur-2xl border-b border-border-light/40">
    <nav class="max-w-5xl mx-auto px-8 h-16 flex items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-heading text-text-primary hover:opacity-50 transition-opacity no-underline">
            HD
        </a>
        <div class="flex gap-10">
            <a 
                href="/" 
                class={`text-sm font-semibold tracking-tight transition-all hover:text-accent-blue no-underline ${currentPath === "" ? "text-text-primary" : "text-text-secondary"}`}
            >
                Home
            </a>
            <a 
                href="/projects" 
                class={`text-sm font-semibold tracking-tight transition-all hover:text-accent-blue no-underline ${currentPath === "projects" ? "text-text-primary" : "text-text-secondary"}`}
            >
                Projects
            </a>
        </div>
    </nav>
</header>
