{
  "name": "phan-portfolio",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "playwright test",
    "test:unit": "vitest run --exclude **/tests/*.spec.ts",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^6.3.1",
    "lucide-astro": "^0.344.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@fontsource/playfair-display": "^5.2.8",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@astrojs/tailwind": {
      "astro": "$astro"
    }
  },
  "lint-staged": {
    "*.{js,ts,astro,json,md}": [
      "prettier --write"
    ],
    "*.{js,ts,astro}": [
      "eslint --fix"
    ]
  }
}
